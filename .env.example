# Copie este arquivo para .env e preencha com suas credenciais reais.
# O .env nunca deve ser commitado (já está no .gitignore).

# URL base do seu site Jira (sem barra no final)
JIRA_BASE_URL=https://SEU-SITE.atlassian.net

# E-mail da conta usada para gerar o API Token
JIRA_EMAIL=seu-email@exemplo.com

# API Token gerado em https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=

# Chave do projeto no Jira (ex: SCRUM, se a issue for SCRUM-1, SCRUM-2...)
JIRA_PROJECT_KEY=SCRUM
